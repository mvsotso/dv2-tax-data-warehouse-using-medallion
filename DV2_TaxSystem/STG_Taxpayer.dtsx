      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT TaxpayerID, TaxID, LegalBusinessName, TradingName, CategoryID, StructureID, &quot;&#xA;+ &quot;RegistrationDate, EstimatedAnnualRevenue, IsActive, CreatedDate, UpdatedDate, &quot;&#xA;+ &quot;N'&quot; + @[User::v_SourceSystem] + &quot;' AS SourceSystem, &quot;&#xA;+ &quot;N'&quot; + @[User::v_RecordSource] + &quot;' AS RecordSource, &quot;&#xA;+ &quot;GETDATE() AS LoadDateTime &quot;&#xA;+ &quot;FROM dbo.&quot; + @[User::v_TableName] + &quot; &quot;&#xA;+ &quot;WHERE UpdatedDate &gt; '&quot; + (DT_WSTR,23)@[User::v_LastWatermark] + &quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="v_SQL_IncrementalLoad">
      <DTS:VariableValue
        DTS:DataType="8">SELECT TaxpayerID, TaxID, LegalBusinessName, TradingName, CategoryID, StructureID, RegistrationDate, EstimatedAnnualRevenue, IsActive, CreatedDate, UpdatedDate, N'TaxSystemDB' AS SourceSystem, N'TaxSystemDB.dbo.Taxpayer' AS RecordSource, GETDATE() AS LoadDateTime FROM dbo.Taxpayer WHERE UpdatedDate &gt; '1/1/1900'</DTS:VariableValue>
