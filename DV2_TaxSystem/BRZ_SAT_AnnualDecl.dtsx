            <component
              refId="Package\DFT_Load_Sat\OLE_SRC"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE_SRC"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    HASHBYTES('SHA2_256', CAST(stg.AnnualDeclarationID AS NVARCHAR(MAX)))
        AS HUB_AnnualDecl_HK,
    GETDATE() AS SAT_LoadDate,
    HASHBYTES('SHA2_256', CONCAT(
        ISNULL(CAST(stg.TaxpayerID AS NVARCHAR(20)), ''), '|',
        ISNULL(CAST(stg.DeclarationYear AS NVARCHAR(4)), ''), '|',
        ISNULL(CAST(stg.GrossRevenue AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.TaxableRevenue AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.TaxAmount AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.PenaltyAmount AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.InterestAmount AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.TotalAmount AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.DeclarationDate AS NVARCHAR(30)), ''), '|',
        ISNULL(CAST(stg.DueDate AS NVARCHAR(30)), ''), '|',
        ISNULL(stg.Status, ''), '|',
        ISNULL(CAST(stg.OfficerID AS NVARCHAR(20)), ''), '|',
        ISNULL(CAST(stg.IsActive AS NVARCHAR(1)), '')
    )) AS SAT_HashDiff,
    stg.RecordSource AS SAT_RecordSource,
    stg.TaxpayerID, stg.DeclarationYear,
    stg.GrossRevenue, stg.TaxableRevenue, stg.TaxAmount,
    stg.PenaltyAmount, stg.InterestAmount, stg.TotalAmount,
    stg.DeclarationDate, stg.DueDate, stg.Status,
    stg.OfficerID, stg.IsActive
FROM DV_Staging.dbo.STG_AnnualDeclaration stg</property>
